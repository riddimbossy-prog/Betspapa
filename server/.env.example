NODE_ENV=development
PORT=4173
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ALLOWED_ORIGINS=http://localhost:5500,http://localhost:4173,https://betspapa.com,https://www.betspapa.com

# Any one of these API-Football aliases may be used. API_FOOTBALL_KEY is preferred.
API_FOOTBALL_KEY=
FOOTBALL_API_KEY=
API_STATS_KEY=
ODDS_API_KEY=

# Long random value used only for protected /api/admin routes.
ADMIN_SYNC_SECRET=


# Public browser authentication configuration.
# SUPABASE_ANON_KEY is safe to expose to the browser.
SUPABASE_ANON_KEY=

# Web Push VAPID credentials.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
PUSH_SUBJECT=mailto:admin@betspapa.com
